# Payment API base URL. Use your machine IP (e.g. http://192.168.1.10:4242) when testing on a physical device.
EXPO_PUBLIC_API_URL=http://localhost:4242

# Stripe publishable key (from https://dashboard.stripe.com/apikeys)
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Supabase (from https://supabase.com/dashboard project Settings > API)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ...
